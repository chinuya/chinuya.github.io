  <entry>
    <title>模板</title>
    <url>/2022/12/20/%E6%A8%A1%E6%9D%BF/</url>
    <content><![CDATA[<h1 id="模板"><a href="#模板" class="headerlink" title="模板"></a>模板</h1><h2 id="二分"><a href="#二分" class="headerlink" title="二分"></a>二分</h2><h3 id="最大值最小"><a href="#最大值最小" class="headerlink" title="最大值最小"></a>最大值最小</h3><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">int</span> <span class="title">main</span><span class="params">()</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="type">int</span> l=<span class="number">1</span>,r=n,mid;</span><br><span class="line">	<span class="keyword">while</span>(l&lt;r)&#123;<span class="comment">//l为开始位置，r为结束位置</span></span><br><span class="line">		mid=(l+r)/<span class="number">2</span>;</span><br><span class="line">		<span class="keyword">if</span>(<span class="built_in">check</span>(mid)==<span class="literal">true</span>)</span><br><span class="line">			r=mid;</span><br><span class="line">		<span class="keyword">else</span></span><br><span class="line">			l=mid+<span class="number">1</span>;</span><br><span class="line">	&#125;</span><br><span class="line">	cout&lt;&lt;l;</span><br><span class="line">	<span class="keyword">return</span> <span class="number">0</span>;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h3 id="最小值最大"><a href="#最小值最大" class="headerlink" title="最小值最大"></a>最小值最大</h3><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">int</span> <span class="title">main</span><span class="params">()</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="type">int</span> l=<span class="number">1</span>,r=n,mid;</span><br><span class="line">	<span class="keyword">while</span>(l&lt;r)&#123;<span class="comment">//l为开始位置，r为结束位置</span></span><br><span class="line">		mid=(l+r+<span class="number">1</span>)/<span class="number">2</span>;</span><br><span class="line">		<span class="keyword">if</span>(<span class="built_in">check</span>(mid)==<span class="literal">true</span>)</span><br><span class="line">			r=mid<span class="number">-1</span>;</span><br><span class="line">		<span class="keyword">else</span></span><br><span class="line">			l=mid;</span><br><span class="line">	&#125;</span><br><span class="line">	cout&lt;&lt;l;</span><br><span class="line">	<span class="keyword">return</span> <span class="number">0</span>;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h3 id="实数二分"><a href="#实数二分" class="headerlink" title="实数二分"></a>实数二分</h3><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="meta">#<span class="keyword">define</span> eps 1e-6<span class="comment">//设置精度</span></span></span><br><span class="line"><span class="function"><span class="type">int</span> <span class="title">main</span><span class="params">()</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="type">double</span> l=<span class="number">1</span>,r=n,mid;</span><br><span class="line">	<span class="keyword">while</span>(r-l&gt;=eps)&#123;<span class="comment">//l为开始位置，r为结束位置</span></span><br><span class="line">		mid=(l+r)/<span class="number">2</span>;</span><br><span class="line">		<span class="keyword">if</span>(<span class="built_in">check</span>(mid)==<span class="literal">true</span>)</span><br><span class="line">			r=mid;</span><br><span class="line">		<span class="keyword">else</span></span><br><span class="line">			l=mid;</span><br><span class="line">	&#125;</span><br><span class="line">	cout&lt;&lt;l;</span><br><span class="line">	<span class="keyword">return</span> <span class="number">0</span>;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h2 id="图论"><a href="#图论" class="headerlink" title="图论"></a>图论</h2><h3 id="二叉树"><a href="#二叉树" class="headerlink" title="二叉树"></a>二叉树</h3><h4 id="建树"><a href="#建树" class="headerlink" title="建树"></a>建树</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="keyword">struct</span> <span class="title class_">node</span>&#123;</span><br><span class="line">	<span class="type">char</span> data;</span><br><span class="line">	node *lc,*rc;</span><br><span class="line">&#125;*root;</span><br><span class="line"><span class="function">node *<span class="title">buildtree</span><span class="params">()</span></span>&#123;</span><br><span class="line">	node *r=<span class="keyword">new</span> node;</span><br><span class="line">	cin&gt;&gt;ch;</span><br><span class="line">	<span class="keyword">if</span>(ch==<span class="string">&#x27;#&#x27;</span>)	<span class="keyword">return</span> <span class="literal">NULL</span>;<span class="comment">//值为空</span></span><br><span class="line">	r-&gt;data=ch;</span><br><span class="line">	r-&gt;lc=<span class="built_in">buildtree</span>();</span><br><span class="line">	r-&gt;rc=<span class="built_in">buildtree</span>();</span><br><span class="line">	<span class="keyword">return</span> r;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h4 id="先序遍历"><a href="#先序遍历" class="headerlink" title="先序遍历"></a>先序遍历</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">preorder</span><span class="params">(node *root)</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="keyword">if</span>(root!=<span class="literal">NULL</span>)&#123;</span><br><span class="line">		cout&lt;&lt;root-&gt;data&lt;&lt;<span class="string">&quot; &quot;</span>;</span><br><span class="line">		<span class="built_in">preorder</span>(root-&gt;lc);</span><br><span class="line">		<span class="built_in">preorder</span>(root-&gt;rc);</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h4 id="中序遍历"><a href="#中序遍历" class="headerlink" title="中序遍历"></a>中序遍历</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">inorder</span><span class="params">(node *root)</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="keyword">if</span>(root!=<span class="literal">NULL</span>)&#123;</span><br><span class="line">		<span class="built_in">inorder</span>(root-&gt;lc);</span><br><span class="line">		cout&lt;&lt;root-&gt;data&lt;&lt;<span class="string">&quot; &quot;</span>;</span><br><span class="line">		<span class="built_in">inorder</span>(root-&gt;rc);</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h4 id="后序遍历"><a href="#后序遍历" class="headerlink" title="后序遍历"></a>后序遍历</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">bhorder</span><span class="params">(node *root)</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="keyword">if</span>(root!=<span class="literal">NULL</span>)&#123;</span><br><span class="line">		<span class="built_in">bhorder</span>(root-&gt;lc);</span><br><span class="line">		<span class="built_in">bhorder</span>(root-&gt;rc);</span><br><span class="line">		cout&lt;&lt;root-&gt;data&lt;&lt;<span class="string">&quot; &quot;</span>;</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h4 id="层次遍历"><a href="#层次遍历" class="headerlink" title="层次遍历"></a>层次遍历</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">levelorder</span><span class="params">(node *root)</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	queue&lt;node *&gt;q;<span class="comment">//定义一个队列</span></span><br><span class="line">	q.<span class="built_in">push</span>(root);<span class="comment">//根节点压入</span></span><br><span class="line">	<span class="keyword">while</span>(!q.<span class="built_in">empty</span>())&#123;<span class="comment">//队列非空</span></span><br><span class="line">		node *r=q.<span class="built_in">front</span>();</span><br><span class="line">		cout&lt;&lt;r-&gt;data&lt;&lt;<span class="string">&quot; &quot;</span>;</span><br><span class="line">		q.<span class="built_in">pop</span>();</span><br><span class="line">		<span class="keyword">if</span>(r-&gt;lc)	q.<span class="built_in">push</span>(r-&gt;lc);<span class="comment">//存在左孩子，压入</span></span><br><span class="line">		<span class="keyword">if</span>(r-&gt;rc)	q.<span class="built_in">push</span>(r-&gt;rc);<span class="comment">//存在右孩子，压入</span></span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>

<h3 id="堆"><a href="#堆" class="headerlink" title="堆"></a>堆</h3><h4 id="手写堆"><a href="#手写堆" class="headerlink" title="手写堆"></a>手写堆</h4><h5 id="向上调整与向下调整"><a href="#向上调整与向下调整" class="headerlink" title="向上调整与向下调整"></a>向上调整与向下调整</h5><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">up</span><span class="params">(<span class="type">int</span> k)</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="type">int</span> f=k/<span class="number">2</span>;<span class="comment">//f为父节点</span></span><br><span class="line">	<span class="keyword">while</span>(f&gt;=<span class="number">1</span>)&#123;</span><br><span class="line">		<span class="keyword">if</span>(h[k]&gt;h[f])&#123;</span><br><span class="line">			<span class="built_in">swap</span>(h[k],h[f]);</span><br><span class="line">			k=f;</span><br><span class="line">			f/=<span class="number">2</span>;</span><br><span class="line">		&#125;</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br><span class="line"><span class="function"><span class="type">void</span> <span class="title">down</span><span class="params">(<span class="type">int</span> k,<span class="type">int</span> high)</span><span class="comment">//把数组在k~high之间调整</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="type">int</span> j=k*<span class="number">2</span>;<span class="comment">//j为左孩子下标</span></span><br><span class="line">	<span class="keyword">while</span>(j&lt;=high)&#123;<span class="comment">//孩子节点存在</span></span><br><span class="line">		<span class="comment">//j存较大孩子下标</span></span><br><span class="line">		<span class="keyword">if</span>(j+<span class="number">1</span>&lt;=high&amp;&amp;h[j+<span class="number">1</span>]&gt;h[j])	j+=<span class="number">1</span>;</span><br><span class="line">		<span class="keyword">if</span>(h[j]&gt;h[k])&#123;</span><br><span class="line">			<span class="built_in">swap</span>(h[j],h[k]);</span><br><span class="line">			k=j;</span><br><span class="line">			j*=<span class="number">2</span>;</span><br><span class="line">		&#125;</span><br><span class="line">		<span class="keyword">else</span> <span class="keyword">break</span>;</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h5 id="建堆"><a href="#建堆" class="headerlink" title="建堆"></a>建堆</h5><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">build</span><span class="params">()</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=n/<span class="number">2</span>;i&gt;=<span class="number">1</span>;i--)&#123;</span><br><span class="line">		<span class="built_in">down</span>(i,n);</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h5 id="插入"><a href="#插入" class="headerlink" title="插入"></a>插入</h5><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">insert</span><span class="params">(<span class="type">int</span> x)</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	h[++n]=x;</span><br><span class="line">	<span class="built_in">up</span>(n);</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h5 id="删除"><a href="#删除" class="headerlink" title="删除"></a>删除</h5><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">delet</span><span class="params">()</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	h[<span class="number">1</span>]=h[n--];</span><br><span class="line">	<span class="built_in">down</span>(<span class="number">1</span>,n);</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h5 id="堆排序"><a href="#堆排序" class="headerlink" title="堆排序"></a>堆排序</h5><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">dui_sort</span><span class="params">()</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="keyword">while</span>(n&gt;<span class="number">1</span>)&#123;</span><br><span class="line">		cout&lt;&lt;h[<span class="number">1</span>]&lt;&lt;<span class="string">&quot; &quot;</span>;</span><br><span class="line">		<span class="built_in">delet</span>();</span><br><span class="line">	&#125;</span><br><span class="line">	cout&lt;&lt;h[<span class="number">1</span>];</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h4 id="STL堆"><a href="#STL堆" class="headerlink" title="STL堆"></a>STL堆</h4><h5 id="大根堆定义"><a href="#大根堆定义" class="headerlink" title="大根堆定义"></a>大根堆定义</h5><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line">priority_queue&lt;<span class="type">int</span>,vector&lt;<span class="type">int</span>&gt; &gt;q;</span><br></pre></td></tr></table></figure>
<h5 id="小根堆定义"><a href="#小根堆定义" class="headerlink" title="小根堆定义"></a>小根堆定义</h5><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line">priority_queue&lt;<span class="type">int</span>,vector&lt;<span class="type">int</span>&gt;,greater&lt;<span class="type">int</span>&gt; &gt;q;</span><br></pre></td></tr></table></figure>
<h5 id="操作"><a href="#操作" class="headerlink" title="操作"></a>操作</h5><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line">q.<span class="built_in">top</span>()<span class="comment">//堆顶元素</span></span><br><span class="line">q.<span class="built_in">push</span>(x)<span class="comment">//在堆中插入元素x</span></span><br><span class="line">q.<span class="built_in">pop</span>()<span class="comment">//堆顶元素出去</span></span><br><span class="line">q.<span class="built_in">empty</span>()<span class="comment">//判断堆是否为空</span></span><br></pre></td></tr></table></figure>
<h3 id="图"><a href="#图" class="headerlink" title="图"></a>图</h3><h4 id="邻接矩阵"><a href="#邻接矩阵" class="headerlink" title="邻接矩阵"></a>邻接矩阵</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="comment">//适用于稠密图</span></span><br><span class="line"><span class="type">int</span> g[N][N];</span><br><span class="line"><span class="function"><span class="type">int</span> <span class="title">main</span><span class="params">()</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	cin&gt;&gt;n&gt;&gt;m;</span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">1</span>;i&lt;=m;i++)&#123;</span><br><span class="line">		cin&gt;&gt;a&gt;&gt;b&gt;&gt;c;</span><br><span class="line">		g[a][b]=c;</span><br><span class="line">		g[b][a]=c;<span class="comment">//无向图</span></span><br><span class="line">	&#125;</span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">1</span>;i&lt;=n;i++)&#123;<span class="comment">//枚举每个点</span></span><br><span class="line">		<span class="keyword">for</span>(<span class="type">int</span> j=<span class="number">1</span>;j&lt;=n;j++)&#123;</span><br><span class="line">			<span class="keyword">if</span>(g[i][j]!=<span class="number">0</span>)&#123;</span><br><span class="line">				<span class="comment">//i，j之间存在边</span></span><br><span class="line">			&#125;</span><br><span class="line">		&#125;</span><br><span class="line">	&#125; </span><br><span class="line">&#125; </span><br></pre></td></tr></table></figure>
<h4 id="邻接表"><a href="#邻接表" class="headerlink" title="邻接表"></a>邻接表</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="comment">//适用于稠密图</span></span><br><span class="line"><span class="keyword">struct</span> <span class="title class_">node</span>&#123;</span><br><span class="line">	<span class="type">int</span> v,w;<span class="comment">//点，边权</span></span><br><span class="line">&#125;; </span><br><span class="line">vector&lt;node&gt; g[N];</span><br><span class="line"><span class="function"><span class="type">int</span> <span class="title">main</span><span class="params">()</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	cin&gt;&gt;n&gt;&gt;m;</span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">1</span>;i&lt;=m;i++)&#123;</span><br><span class="line">		cin&gt;&gt;a&gt;&gt;b&gt;&gt;c;</span><br><span class="line">		g[a].<span class="built_in">push_back</span>(&#123;b,c&#125;);</span><br><span class="line">		g[b].<span class="built_in">push_back</span>(&#123;a,c&#125;); </span><br><span class="line">	&#125;</span><br><span class="line">	<span class="comment">//遍历节点u对应的所有边 </span></span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">0</span>;i&lt;g[u].<span class="built_in">size</span>();i++)&#123;<span class="comment">//注意此处起止位置</span></span><br><span class="line">		<span class="type">int</span> v=g[u][i].v;</span><br><span class="line">		<span class="type">int</span> w=g[u][i].w;</span><br><span class="line">	 &#125; </span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h4 id="DFS遍历"><a href="#DFS遍历" class="headerlink" title="DFS遍历"></a>DFS遍历</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="function"><span class="type">void</span> <span class="title">dfs</span><span class="params">(<span class="type">int</span> i)</span><span class="comment">//用数组模拟邻接表存储，访问点i</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">    v[i]=<span class="literal">true</span>;<span class="comment">//标记为已经访问过</span></span><br><span class="line">    <span class="keyword">for</span>(<span class="type">int</span> j=<span class="number">0</span>;j&lt;g[i].<span class="built_in">size</span>();j++)<span class="comment">//遍历与i相关联的所有未访问过的顶点</span></span><br><span class="line">        <span class="keyword">if</span>(v[g[i][j]]!=<span class="number">0</span>)<span class="comment">//如果没访问过</span></span><br><span class="line">            <span class="built_in">dfs</span>(g[i][j]);</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h4 id="欧拉路与欧拉回路"><a href="#欧拉路与欧拉回路" class="headerlink" title="欧拉路与欧拉回路"></a>欧拉路与欧拉回路</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line"><span class="meta">#<span class="keyword">include</span><span class="string">&lt;bits/stdc++.h&gt;</span></span></span><br><span class="line"><span class="keyword">using</span> <span class="keyword">namespace</span> std;</span><br><span class="line"><span class="type">int</span> g[<span class="number">1001</span>][<span class="number">1001</span>],u,n,m,a,b,d[<span class="number">1001</span>]; </span><br><span class="line"><span class="function"><span class="type">void</span> <span class="title">dfs</span><span class="params">(<span class="type">int</span> u)</span><span class="comment">//对奇数度的点进行dfs，没有则dfs点1</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">1</span>;i&lt;=n;i++)&#123;<span class="comment">//循环遍历u点的每一条连边</span></span><br><span class="line">		<span class="keyword">if</span>(g[u][i]!=<span class="number">0</span>)&#123;</span><br><span class="line">			g[u][i]--;</span><br><span class="line">			g[i][u]--;</span><br><span class="line">			<span class="built_in">dfs</span>(i);</span><br><span class="line">		&#125;</span><br><span class="line">	&#125;</span><br><span class="line">	cout&lt;&lt;u&lt;&lt;<span class="string">&quot; &quot;</span>;</span><br><span class="line">&#125;</span><br><span class="line"><span class="function"><span class="type">int</span> <span class="title">main</span><span class="params">()</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	cin&gt;&gt;n&gt;&gt;m;<span class="comment">//假设使用邻接矩阵存储</span></span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">1</span>;i&lt;=m;i++)&#123;</span><br><span class="line">		cin&gt;&gt;a&gt;&gt;b;</span><br><span class="line">		g[a][b]++;</span><br><span class="line">		g[b][a]++;<span class="comment">//由于是无向图，所以g[a][b]和g[b][a]都要++</span></span><br><span class="line">		d[a]++;</span><br><span class="line">		d[b]++;<span class="comment">//计算a、b点的度</span></span><br><span class="line">	&#125;</span><br><span class="line">	u=<span class="number">1</span>;<span class="comment">//奇数度的点初值为点1</span></span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">1</span>;i&lt;=n;i++)&#123;</span><br><span class="line">		<span class="keyword">if</span>(d[i]%<span class="number">2</span>==<span class="number">1</span>)&#123;</span><br><span class="line">			u=i;</span><br><span class="line">			<span class="keyword">break</span>;</span><br><span class="line">		&#125;</span><br><span class="line">	&#125;</span><br><span class="line">	<span class="built_in">dfs</span>(u);</span><br><span class="line">	<span class="keyword">return</span> <span class="number">0</span>;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<h4 id="拓扑序列"><a href="#拓扑序列" class="headerlink" title="拓扑序列"></a>拓扑序列</h4><figure class="highlight cpp"><table><tr><td class="code"><pre><span class="line">vector&lt;<span class="type">int</span>&gt; g[<span class="number">1005</span>];<span class="comment">//邻接表存储</span></span><br><span class="line"><span class="type">int</span> ans[<span class="number">1005</span>],rd[<span class="number">1005</span>];<span class="comment">//答案序列和入度</span></span><br><span class="line"><span class="function"><span class="type">bool</span> <span class="title">top_sort</span><span class="params">()</span><span class="comment">//拓扑排序，有拓扑序返回真并输出序列，否则返回假</span></span></span><br><span class="line"><span class="function"></span>&#123;</span><br><span class="line">	queue&lt;<span class="type">int</span>&gt; s;</span><br><span class="line">	<span class="type">int</span> cnt;</span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">1</span>;i&lt;=n;i++)&#123;</span><br><span class="line">		<span class="keyword">if</span>(rd[i]==<span class="number">0</span>)	s.<span class="built_in">push</span>(i);<span class="comment">//找到入度为0的点就push进队</span></span><br><span class="line">	&#125;</span><br><span class="line">	<span class="keyword">while</span>(!s.<span class="built_in">empty</span>())&#123;</span><br><span class="line">		<span class="type">int</span> u=s.<span class="built_in">top</span>();<span class="comment">//取队首元素</span></span><br><span class="line">		s.<span class="built_in">pop</span>();<span class="comment">//弹出队首元素</span></span><br><span class="line">		ans[++cnt]=q;<span class="comment">//记录拓扑序列</span></span><br><span class="line">		<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">0</span>;i&lt;g[u].<span class="built_in">size</span>();i++)&#123;</span><br><span class="line">			<span class="type">int</span> v=g[u][i];</span><br><span class="line">			rd[v]--;<span class="comment">//入度减一</span></span><br><span class="line">			<span class="keyword">if</span>(rd[v]==<span class="number">0</span>)&#123;<span class="comment">//如果存在入度为0的点，则入队</span></span><br><span class="line">				s.<span class="built_in">push</span>(v);</span><br><span class="line">			&#125;</span><br><span class="line">		&#125;</span><br><span class="line">	&#125;</span><br><span class="line">	<span class="keyword">if</span>(cnt&lt;n)	<span class="keyword">return</span> <span class="literal">false</span>;<span class="comment">//没有遍历所有点，说明存在环。</span></span><br><span class="line">	<span class="keyword">for</span>(<span class="type">int</span> i=<span class="number">1</span>;i&lt;=cnt;i++)&#123;</span><br><span class="line">		cout&lt;&lt;ans[i]&lt;&lt;<span class="string">&quot; &quot;</span>;<span class="comment">//输出拓扑序列</span></span><br><span class="line">	&#125;</span><br><span class="line">	<span class="keyword">return</span> <span class="literal">true</span>;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>]]></content>
